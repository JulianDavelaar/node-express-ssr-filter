{% render 'partials/head.liquid', selectedType:selectedType %}

<main>
  <header>
    <h1>
      Nerdy pizza's <small>{{ meta.filter_count }} / {{ meta.total_count }}</small>
    </h1>

    <p>
    {% if selectedType != "" %}
      {% case selectedType %}
        {% when "vegetarisch" %}
          {% assign icon = "🥦" %}
        {% when "vlees" %}
          {% assign icon = "🥩" %}
        {% when "vis" %}
          {% assign icon = "🐟" %}
        {% else %}
          {% assign icon = "🍕" %}
      {% endcase %}
      Je hebt gefiltered op: <strong>{{selectedType}} {{ icon }}</strong>
    {% endif %}
    </p>
  </header>
  
  {% for pizza in pizzas %}
    <a href="/pizzas/{{pizza.slug}}">
      {% render 'partials/pizza_card.liquid', pizza:pizza %}
    </a>
  {% endfor %}
</main>

{% render 'partials/foot.liquid' %}
